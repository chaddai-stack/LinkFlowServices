LINKFLOW_PUBLIC_BASE_URL=http://linkflow.127.0.0.1.nip.io:8080

LINKFLOW_QR_S3_ENABLED=true
LINKFLOW_QR_S3_BUCKET=linkflow-qrcodes
LINKFLOW_QR_S3_REGION=us-west-1
LINKFLOW_QR_S3_PREFIX=qrcodes
LINKFLOW_QR_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=replace-with-your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-aws-secret-access-key

LINKFLOW_SLUG_LLM_ENABLED=true
LINKFLOW_SLUG_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LINKFLOW_SLUG_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-with-your-openai-api-key
